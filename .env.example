# Copy to ".env" and fill in real values. Never commit your real .env.

# Flask session signing key. REQUIRED in production.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Token required to access /admin. Leave empty to disable the admin page.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(24))"
ADMIN_TOKEN=

# Set to 1 in production (HTTPS) so the session cookie is marked Secure.
SESSION_COOKIE_SECURE=0

# Set to 1 to enable Flask debug / auto-reload locally.
FLASK_DEBUG=0

# How long generated upload/output files live before deletion, in seconds.
FILE_TTL_SECONDS=3600
